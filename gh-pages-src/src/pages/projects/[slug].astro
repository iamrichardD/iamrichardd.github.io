---
/**
 * Project: iamrichardd.github.io
 * Component: ProjectDetail
 * File: [slug].astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * Purpose: Dynamic project case study template.
 * Traceability: Core Architectural Standard
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} - iamrichardD`} description={project.data.description}>
    <main id="main-content">
      <!-- Project Header -->
      <section class="section bg-gradient-to-br from-primary-50 to-secondary-50 dark:from-secondary-900 dark:to-secondary-800 border-b border-secondary-200 dark:border-secondary-700 pt-32">
        <div class="container-custom">
          <div class="max-w-4xl mx-auto">
            <h1 class="text-4xl md:text-5xl font-bold mb-6">{project.data.title}</h1>
            <p class="text-xl text-secondary-600 dark:text-secondary-400 mb-8 leading-relaxed max-w-3xl">
              {project.data.description}
            </p>
            
            <div class="flex flex-wrap gap-8 mb-8 border-y border-secondary-200 dark:border-secondary-800 py-6">
              <div>
                <span class="block text-xs uppercase tracking-wider text-secondary-500 font-bold mb-1">Role</span>
                <span class="font-semibold text-secondary-900 dark:text-secondary-100">{project.data.role}</span>
              </div>
              <div>
                <span class="block text-xs uppercase tracking-wider text-secondary-500 font-bold mb-1">Published</span>
                <span class="font-semibold text-secondary-900 dark:text-secondary-100">{project.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              </div>
            </div>

            <div class="flex flex-wrap gap-4">
              <a href={project.data.links.github} target="_blank" rel="noopener noreferrer" class="btn btn-outline px-6 py-3">
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.30.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                GitHub Repository
              </a>
              {project.data.links.site && (
                <a href={project.data.links.site} target="_blank" rel="noopener noreferrer" class="btn btn-outline px-6 py-3">
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                  Project Site
                </a>
              )}
            </div>
          </div>
        </div>
      </section>

      <!-- Case Study Content -->
      <section class="section">
        <div class="container-custom">
          <div class="max-w-4xl mx-auto">
            <div class="grid md:grid-cols-[1fr_300px] gap-16">
              <!-- Main Content -->
              <article class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-primary-600 dark:prose-a:text-primary-400 prose-img:rounded-xl">
                <Content />
              </article>

              <!-- Sidebar Sidebar -->
              <aside class="space-y-10">
                <div class="bg-secondary-50 dark:bg-secondary-800/50 p-6 rounded-xl border border-secondary-200 dark:border-secondary-700">
                  <h3 class="text-sm uppercase tracking-wider text-secondary-500 font-bold mb-6">Methodology</h3>
                  <div class="flex flex-wrap gap-2">
                    {project.data.methods.map((method) => (
                      <span class="px-3 py-1 bg-white dark:bg-secondary-800 text-secondary-700 dark:text-secondary-300 rounded-lg text-xs font-bold border border-secondary-200 dark:border-secondary-600 shadow-sm">
                        {method}
                      </span>
                    ))}
                  </div>
                </div>

                <div class="bg-secondary-50 dark:bg-secondary-800/50 p-6 rounded-xl border border-secondary-200 dark:border-secondary-700">
                  <h3 class="text-sm uppercase tracking-wider text-secondary-500 font-bold mb-6">Technologies</h3>
                  <div class="flex flex-wrap gap-2">
                    {project.data.tags.map((tag) => (
                      <span class="px-3 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-lg text-xs font-bold border border-primary-200 dark:border-primary-800 shadow-sm">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </aside>
            </div>
          </div>
        </div>
      </section>

      <!-- Footer CTA -->
      <section class="section bg-secondary-900 text-white dark:bg-secondary-800/30">
        <div class="container-custom text-center">
          <h2 class="text-3xl font-bold mb-6">Interested in High-Rigor Architecture?</h2>
          <p class="text-xl text-secondary-300 dark:text-secondary-400 mb-10 max-w-2xl mx-auto leading-relaxed">
            I specialize in building deterministic systems that reduce organizational toil. Let's discuss how I can help your team scale.
          </p>
          <div class="flex justify-center gap-4">
            <a href="/#contact" class="btn bg-white text-secondary-900 hover:bg-secondary-100 px-8 py-4 text-lg font-bold">Get In Touch</a>
            <a href="/projects" class="btn border-white/30 text-white hover:bg-white/10 px-8 py-4 text-lg font-bold border">All Projects</a>
          </div>
        </div>
      </section>
    </main>
</BaseLayout>
