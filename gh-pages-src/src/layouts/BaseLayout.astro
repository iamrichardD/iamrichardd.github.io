---
/**
 * Project: iamrichardd.github.io
 * Layout: BaseLayout
 * File: BaseLayout.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * Purpose: Global layout wrapper for consistent branding and navigation.
 * Traceability: Core Architectural Standard
 */
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = "iamrichardD - Senior Engineering Manager", 
  description = "Senior Engineering Manager specializing in scalable software architecture, team leadership, and innovative technology solutions.",
  image = "https://avatars.githubusercontent.com/u/182445865?v=4"
} = Astro.props;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="https://avatars.githubusercontent.com/u/182445865?v=4&s=32" sizes="32x32" />
    <link rel="icon" type="image/png" href="https://avatars.githubusercontent.com/u/182445865?v=4&s=16" sizes="16x16" />
    <link rel="apple-touch-icon" href="https://avatars.githubusercontent.com/u/182445865?v=4&s=180" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <script is:inline>
      // Apply dark mode immediately
      if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="72cdde11-d1e4-4a33-9cc3-a00d5fe4651b"></script>
  </head>
  <body class="antialiased bg-white dark:bg-secondary-900 text-secondary-900 dark:text-secondary-100 min-h-screen pt-16">
    <Header />
    <slot />
    
    <footer class="bg-secondary-50 dark:bg-secondary-800/50 border-t border-secondary-200 dark:border-secondary-800 py-12">
      <div class="container-custom text-center">
        <p class="text-secondary-600 dark:text-secondary-400">
          © {new Date().getFullYear()} iamrichardD. Built with Astro & TDD.
        </p>
      </div>
    </footer>
  </body>
</html>
