---
/**
 * Project: iamrichardd.github.io
 * Component: ProjectCard
 * File: ProjectCard.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * Purpose: Reusable project summary card.
 * Traceability: VSA Architecture
 */
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;
---

<div class:list={[
  "group relative overflow-hidden rounded-2xl border transition-all duration-300",
  featured 
    ? "bg-gradient-to-br from-secondary-900 to-secondary-800 border-secondary-700 text-white" 
    : "bg-white dark:bg-secondary-800 border-secondary-200 dark:border-secondary-700 hover:shadow-xl hover:-translate-y-1"
]}>
  <div class="p-8">
    <div class="flex items-start justify-between mb-6">
      <div class:list={[
        "w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0",
        featured ? "bg-white text-secondary-900" : "bg-primary-600 text-white"
      ]}>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
      </div>
      
      <div class="flex gap-2">
        <a 
          href={project.data.links.github} 
          target="_blank" 
          rel="noopener noreferrer"
          class:list={[
            "p-2 rounded-lg transition-colors",
            featured ? "hover:bg-white/10" : "hover:bg-secondary-100 dark:hover:bg-secondary-700"
          ]}
          aria-label="GitHub Repository"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.30.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>

    <h3 class:list={[
      "text-2xl font-bold mb-2",
      featured ? "text-white" : "text-secondary-900 dark:text-secondary-100"
    ]}>
      {project.data.title}
    </h3>
    <p class:list={[
      "text-sm font-medium mb-4 uppercase tracking-wider",
      featured ? "text-primary-300" : "text-primary-600 dark:text-primary-400"
    ]}>
      {project.data.role}
    </p>
    <p class:list={[
      "mb-8 leading-relaxed line-clamp-3",
      featured ? "text-secondary-300" : "text-secondary-600 dark:text-secondary-400"
    ]}>
      {project.data.description}
    </p>

    <div class="flex flex-wrap gap-2 mb-8">
      {project.data.tags.slice(0, 3).map((tag) => (
        <span class:list={[
          "px-2 py-1 rounded text-[10px] font-bold uppercase tracking-widest",
          featured ? "bg-white/10 text-white" : "bg-secondary-100 dark:bg-secondary-700 text-secondary-600 dark:text-secondary-300"
        ]}>
          {tag}
        </span>
      ))}
    </div>

    <a 
      href={`/projects/${project.slug}`} 
      class:list={[
        "inline-flex items-center gap-2 font-bold transition-all group/link",
        featured ? "text-white hover:text-primary-300" : "text-primary-600 dark:text-primary-400 hover:text-primary-700"
      ]}
    >
      Read Case Study
      <svg class="w-4 h-4 transform transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
      </svg>
    </a>
  </div>
</div>
